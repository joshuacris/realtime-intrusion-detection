{
  "uid": "ids-pipeline",
  "title": "IDS Pipeline",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Throughput (flows/sec)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(ids_flows_ingested_total[1m])", "legendFormat": "features encoded/s" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(ids_scored_total[1m])", "legendFormat": "scored/s" }
      ]
    },
    {
      "id": 2,
      "title": "Inference latency (p50 / p99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(ids_inference_latency_seconds_bucket[1m])) by (le))", "legendFormat": "p50" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(ids_inference_latency_seconds_bucket[1m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 3,
      "title": "Alert rate (fired vs suppressed)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(ids_alerts_fired_total[1m])", "legendFormat": "fired/s" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(ids_alerts_suppressed_total[1m])", "legendFormat": "suppressed/s" }
      ]
    },
    {
      "id": 4,
      "title": "Kafka consumer lag",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(kafka_consumergroup_lag) by (consumergroup)", "legendFormat": "{{consumergroup}}" }
      ]
    },
    {
      "id": 5,
      "title": "Total scored",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 16 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "ids_scored_total" }
      ]
    },
    {
      "id": 6,
      "title": "Alerts fired (total)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 16 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "ids_alerts_fired_total" }
      ]
    }
  ]
}